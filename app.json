{
  "expo": {
    "name": "Tiffin Mate",
    "slug": "tiffin-mate",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5b6af0"
    },
    "android": {
      "package": "com.tanishq.tiffinmate",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5b6af0"
      }
    },
    "ios": {
      "bundleIdentifier": "com.tanishq.tiffinmate"
    },
    "extra": {
      "eas": {
        "projectId": "9a54f141-e55b-4ec2-890d-e121c4a59855"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
